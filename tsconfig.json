{
    "compilerOptions": {
        "experimentalDecorators": true,
        "verbatimModuleSyntax": true,
        "erasableSyntaxOnly": true,

        "module": "ES2022",
        "target": "ES2020",
        "lib": ["ES2022"],

        "declaration": true,
        "inlineSourceMap": true,
        "outDir": "build",
        "removeComments": true,
        "skipLibCheck": true,
        "rootDir": ".",

        "strict": true,
        "moduleResolution": "Bundler",
        "typeRoots": ["./.gnim/types", "./node_modules/@types"]
    },
    "include": ["./lib/**/*", "./bin/**/*"]
}
