{
    "compilerOptions": {
        "experimentalDecorators": true,
        "erasableSyntaxOnly": true,

        "module": "ES2022",
        "target": "ES2020",
        "lib": ["ES2022"],

        "declaration": true,
        "inlineSourceMap": true,
        "outDir": "build",
        "removeComments": true,
        "skipLibCheck": true,
        "rootDir": ".",

        "allowJs": true,
        "checkJs": true,

        "strict": true,
        "moduleResolution": "Bundler",
        "verbatimModuleSyntax": true,
        "typeRoots": ["./.types"],

        "baseUrl": ".",
        "jsx": "react-jsx",
        "jsxImportSource": "lib"
    }
}
