{
    "compilerOptions": {
        "module": "nodenext",
        "target": "ES2020",

        "inlineSourceMap": true,
        "outDir": "build/bin",
        "removeComments": true,
        "skipLibCheck": true,

        "strict": true,
        "verbatimModuleSyntax": true,
        "moduleResolution": "nodenext"
    },
    "include": ["./bin/**/*"]
}
