{
    "compilerOptions": {
        "module": "ES2022",
        "target": "ES2020",
        "lib": ["ES2022"],

        "declaration": true,
        "inlineSourceMap": true,
        "outDir": "build/lib",
        "removeComments": true,
        "skipLibCheck": true,

        "strict": true,
        "moduleResolution": "Bundler",
        "verbatimModuleSyntax": true,
        "typeRoots": ["./.types"],
        "baseUrl": ".",

        "jsx": "react-jsx",
        "jsxImportSource": "lib"
    },
    "include": ["./lib/**/*"]
}
