{
    "compilerOptions": {
        "module": "ES2022",
        "target": "ES2020",
        "lib": ["ES2022"],
        "outDir": "build",
        "removeComments": true,
        "inlineSourceMap": true,
        "strict": true,
        "moduleResolution": "Bundler",
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "verbatimModuleSyntax": true,
        "typeRoots": ["./.gi"]
    },
    "include": ["./src/**/*"]
}
