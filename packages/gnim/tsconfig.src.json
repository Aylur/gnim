{
    "compilerOptions": {
        "module": "ES2022",
        "target": "ES2020",
        "lib": ["ES2022"],

        "declaration": true,
        "inlineSourceMap": true,
        "outDir": "build/src",
        "removeComments": true,
        "skipLibCheck": true,

        "strict": true,
        "moduleResolution": "Bundler",
        "verbatimModuleSyntax": true,
        "typeRoots": ["./.types"],

        "jsx": "react-jsx",
        "jsxImportSource": "./gtk4"
    },
    "include": ["./src/**/*"]
}
