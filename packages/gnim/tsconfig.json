{
    "compilerOptions": {
        "experimentalDecorators": true,
        "verbatimModuleSyntax": true,
        "erasableSyntaxOnly": true,

        "module": "ES2022",
        "target": "ES2020",
        "lib": ["ES2022"],

        "declaration": true,
        "inlineSourceMap": true,
        "outDir": "dist",
        "skipLibCheck": true,

        "strict": true,
        "moduleResolution": "Bundler",
        "types": ["node", "gi"],
        "typeRoots": ["../../.gnim/types", "./node_modules/@types"]
    },
    "include": ["./lib/**/*", "./bin/**/*"]
}
