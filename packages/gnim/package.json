{
    "name": "gnim",
    "version": "2.0.0-alpha.5",
    "type": "module",
    "author": "Aylur",
    "license": "MIT",
    "repository": "github:Aylur/gnim",
    "funding": {
        "type": "kofi",
        "url": "https://ko-fi.com/aylur"
    },
    "bin": {
        "gnim": "bin/gnim.js"
    },
    "optionalDependencies": {
        "@gnim-js/linux-x64": "2.0.0-alpha.5"
    },
    "exports": {
        ".": {
            "import": "./lib/index.js",
            "types": "./lib/index.d.ts"
        },
        "./dbus": {
            "import": "./lib/decorators/dbus.js",
            "types": "./lib/decorators/dbus.d.ts"
        },
        "./gobject": {
            "import": "./lib/decorators/gobject.js",
            "types": "./lib/decorators/gobject.d.ts"
        },
        "./i18n": {
            "import": "./lib/i18n/index.js",
            "types": "./lib/i18n/index.d.ts"
        },
        "./schema": {
            "import": "./lib/schema/index.js",
            "types": "./lib/schema/index.d.ts"
        },
        "./fetch": {
            "import": "./lib/polyfill/fetch.js",
            "types": "./lib/polyfill/fetch.d.ts"
        },
        "./jsx-runtime": {
            "import": "./lib/jsx-runtime.js",
            "types": "./lib/jsx-runtime.d.ts"
        },
        "./jsx-dev-runtime": {
            "import": "./lib/jsx-dev-runtime.js",
            "types": "./lib/jsx-dev-runtime.d.ts"
        },
        "./gtk4": {
            "import": "./lib/renderer/gtk4/index.js",
            "types": "./lib/renderer/gtk4/index.d.ts"
        }
    },
    "files": [
        "bin",
        "lib"
    ],
    "engines": {
        "gjs": ">=1.83.0"
    },
    "keywords": [
        "GJS",
        "Gnome",
        "GTK",
        "JSX"
    ]
}
